<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>

		<!-- SSH principal -->
		<add key="MainHost" value="s.ingeniapp.com" />
		<add key="MainUser" value="alex" />
		<add key="PemPath" value="C:\Proyecto Busmatick\desarrollo.pem" />

		<!-- Bastion -->
		<add key="BastionHost" value="54.167.16.87" />
		<add key="BastionUser" value="admin" />

		<!-- Password GLOBAL (SSH bastión/concentrador). Para su - como root se usa la misma salvo que defina SuRootPassword. -->
		<add key="GlobalPassword" value="BusmatickApp1" />
		<!-- Opcional: solo si la contraseña de root en el concentrador no es la misma que GlobalPassword. -->
		<!-- <add key="SuRootPassword" value="" /> -->

		<!-- Opcional -->
		<add key="ShellTimeoutMs" value="15000" />
		<add key="CommandWaitMs" value="4000" />

		<!-- DB viewer (docker exec). Si DbPassword está vacío se usa GlobalPassword. -->
		<!-- En imágenes mariadb:latest el cliente es "mariadb"; en otras puede ser "mysql" o ruta absoluta. -->
		<add key="DbClientBinary" value="mariadb" />
		<add key="DbContainerName" value="concentrador_db" />
		<add key="DbSchema" value="concentrador" />
		<add key="DbUser" value="root" />
		<add key="DbPassword" value="" />

	</appSettings>
</configuration>